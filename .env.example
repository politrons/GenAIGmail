# Gmail search scope for MCP tool
GMAIL_MAILBOX=INBOX
GMAIL_SEARCH_CRITERION=ALL
GMAIL_MAX_EMAILS=250
GMAIL_MAX_BODY_CHARS=5000
GMAIL_CHUNKS_PATH=data/gmail_chunks.jsonl

# Prompt optimization (optional, DSPy)
DSPY_COMPILER_MODEL=ollama_chat/llama3.1:8b
DSPY_API_BASE=
DSPY_API_KEY=

# Local inference model settings
LOCAL_HF_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
LOCAL_HF_TASK=text-generation
LOCAL_MAX_NEW_TOKENS=220
LOCAL_TEMPERATURE=0.0
LOCAL_RAG_TOP_K=6
LOCAL_RAG_MIN_SCORE=0.01
LOCAL_MAX_SNIPPET_CHARS=420

# MCP Gmail transport (required)
MCP_SERVER_COMMAND=npx -y google-workspace-mcp serve
MCP_GMAIL_SEARCH_TOOL=searchGmail
MCP_GMAIL_SEND_TOOL=sendGmailDraft
MCP_GMAIL_ACCOUNT=
MCP_STARTUP_TIMEOUT=20
MCP_REQUEST_TIMEOUT=45

# Optional knowledge-base chunks
RAG_CHUNKS_PATH=data/knowledge_base_chunks.jsonl
